APP_PORT=8000

# Railway/Supabase production config:
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres

# Local fallback config if DATABASE_URL is not set:
DB_HOST=aws-1-ap-south-1.pooler.supabase.com
DB_PORT=6543
DB_NAME=postgres
DB_USER=postgres.PROJECT_REF
DB_PASSWORD=your-password

JWT_SECRET=change-me
JWT_EXPIRES_IN=1h
ENCRYPTION_KEY=32-byte-encryption-key-goes-here
ENCRYPTION_REQUIRED=false

# Optional email config for sending OTPs.
# Prefer Resend on Railway because SMTP ports can timeout.
APP_NAME=Aashanway
MAIL_FROM=Aashanway <onboarding@resend.dev>
RESEND_API_KEY=re_your_api_key
RESEND_FROM=Aashanway <onboarding@resend.dev>

# SMTP fallback with nodemailer.
# If no mail provider is configured, OTP APIs return the OTP in the response for local testing.
# The app forces IPv4 in code to avoid ENETUNREACH on Railway.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com
