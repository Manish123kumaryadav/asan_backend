APP_PORT=8000

# Railway/Supabase production config:
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres

# Local fallback config if DATABASE_URL is not set:
DB_HOST=aws-1-ap-south-1.pooler.supabase.com
DB_PORT=6543
DB_NAME=postgres
DB_USER=postgres.PROJECT_REF
DB_PASSWORD=your-password

JWT_SECRET=change-me
JWT_EXPIRES_IN=1h
ENCRYPTION_KEY=32-byte-encryption-key-goes-here
ENCRYPTION_REQUIRED=false

# ── Email config ────────────────────────────────────────────────────────────
APP_NAME=Aashanway

# OPTION 1 (recommended for Railway/cloud): Resend HTTP API
# Sign up free at https://resend.com → Dashboard → API Keys → Create
# Free tier: 100 emails/day, no SMTP port issues.
# Set RESEND_FROM to a verified sender (or leave blank to use onboarding@resend.dev for testing)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM=you@yourdomain.com

# OPTION 2 (local dev only): Gmail SMTP via nodemailer
# Works locally but Railway blocks port 587. Used automatically if RESEND_API_KEY is not set.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=your-email@gmail.com
